                <div style={{ color: "rgba(255,255,255,0.18)", fontSize: 18 }}>›</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* ── POSITION DETAIL ── */}
    {tab === "positions" && holding && (
      <div>
        <button onClick={() => setSelected(null)} style={{ display: "inline-flex", alignItems: "center", gap: 4, background: "rgba(255,255,255,0.07)", border: "1px solid rgba(255,255,255,0.1)", color: "rgba(255,255,255,0.58)", padding: "6px 14px", borderRadius: 100, cursor: "pointer", fontSize: 13, fontFamily: "inherit", marginBottom: 18, transition: "opacity 0.15s" }}>‹ Back</button>

        <div className="glass fade-in" style={{ ...styles.glass, padding: "24px", marginBottom: 12, animationDelay: "0ms", background: `linear-gradient(145deg, ${holding.gradient[0]}14 0%, rgba(28,28,30,0.85) 60%)`, border: `1px solid ${holding.gradient[0]}25` }}>
          <div style={{ display: "flex", alignItems: "center", gap: 16, marginBottom: 20 }}>
            <div style={{ width: 58, height: 58, borderRadius: 16, flexShrink: 0, background: `linear-gradient(135deg, ${holding.gradient[0]}, ${holding.gradient[1]})`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 24, fontWeight: 800, color: "#fff", boxShadow: `0 6px 24px ${holding.gradient[0]}55` }}>{holding.icon}</div>
            <div style={{ flex: 1 }}>
              <div style={{ fontSize: 28, fontWeight: 700, letterSpacing: "-0.04em" }}>{holding.ticker}</div>
              <div style={{ fontSize: 13, color: "rgba(255,255,255,0.38)" }}>{holding.name}</div>
            </div>
            <div style={{ textAlign: "right" }}>
              <div style={{ fontSize: 26, fontWeight: 700, letterSpacing: "-0.03em" }}>${holding.currentPrice}</div>
              <div style={{ fontSize: 13, color: holding.gainPct >= 0 ? "#30D158" : "#FF453A", fontWeight: 600 }}>{holding.gainPct >= 0 ? "+" : ""}{holding.gainPct}%</div>
            </div>
          </div>
          <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
            {[["Total Value", fmt(holding.totalValue)], ["PE", `${holding.pe}×`], ["Fwd PE", `${holding.forwardPe}×`], ["Target", `$${holding.analystTarget}`], ["Upside", `+${holding.upside}%`]].map(([label, value]) => (
              <div key={label} style={{ ...styles.glassLight, padding: "10px 13px", flex: "1 1 70px" }}>
                <div style={{ fontSize: 9, color: "rgba(255,255,255,0.28)", textTransform: "uppercase", letterSpacing: "0.06em", marginBottom: 4, fontWeight: 600 }}>{label}</div>
                <div style={{ fontSize: 14, fontWeight: 700, letterSpacing: "-0.02em" }}>{value}</div>
              </div>
            ))}
          </div>
        </div>

        <div style={styles.sectionLabel}>By Account</div>
        <div className="glass fade-in" style={{ ...styles.glass, padding: "0 18px", marginBottom: 12, animationDelay: "60ms" }}>
          {holding.accounts.map((acc, i, arr) => (
            <div key={acc.name} style={{ ...styles.row, borderBottom: i < arr.length - 1 ? styles.row.borderBottom : "none" }}>
              <div>
                <div style={{ fontSize: 15, fontWeight: 500 }}>{acc.name}</div>
                <div style={{ fontSize: 12, color: "rgba(255,255,255,0.28)", marginTop: 2 }}>{typeof acc.shares === "number" ? acc.shares.toFixed(2) : acc.shares} shares</div>
              </div>
              <div style={{ textAlign: "right" }}>
                <div style={{ fontSize: 15, fontWeight: 600 }}>{fmt(acc.value)}</div>
                <div style={{ fontSize: 12, color: acc.gainPct >= 0 ? "#30D158" : "#FF453A", fontWeight: 500, marginTop: 2 }}>{acc.gainPct >= 0 ? "+" : ""}{acc.gainPct.toFixed(1)}%</div>
              </div>
            </div>
          ))}
        </div>

        <div style={styles.sectionLabel}>Investment Thesis</div>
        <div className="glass fade-in" style={{ ...styles.glass, padding: "18px 20px", marginBottom: 12, animationDelay: "120ms" }}>
          <div style={{ fontSize: 14, color: "rgba(255,255,255,0.68)", lineHeight: 1.72 }}>{holding.thesis}</div>
        </div>

        <div style={styles.sectionLabel}>Key Catalysts</div>
        <div className="glass fade-in" style={{ ...styles.glass, padding: "0 20px", marginBottom: 12, animationDelay: "180ms" }}>
          {holding.catalysts.map((c, i, arr) => (
            <div key={i} style={{ ...styles.row, borderBottom: i < arr.length - 1 ? styles.row.borderBottom : "none" }}>
              <div style={{ display: "flex", gap: 12, alignItems: "center" }}>
                <div style={{ width: 6, height: 6, borderRadius: 100, background: holding.gradient[0], flexShrink: 0 }} />
                <div style={{ fontSize: 14, color: "rgba(255,255,255,0.62)", lineHeight: 1.5 }}>{c}</div>
              </div>
            </div>
          ))}
        </div>

        <div style={{ ...styles.sectionLabel, color: "rgba(255,69,58,0.55)" }}>Risk Factors</div>
        <div className="glass fade-in" style={{ ...styles.glass, padding: "18px 20px", marginBottom: 12, animationDelay: "240ms", background: "rgba(255,69,58,0.04)", border: "1px solid rgba(255,69,58,0.12)" }}>
          <div style={{ fontSize: 14, color: "rgba(255,255,255,0.52)", lineHeight: 1.7 }}>{holding.risks}</div>
        </div>
      </div>
    )}

    {/* ── OUTLOOK ── */}
    {tab === "outlook" && (
      <div>
        <div style={styles.sectionLabel}>Long-Term Conviction</div>
        <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
          {[...holdings].sort((a, b) => b.conviction - a.conviction).map((h, i) => {
            const c = h.conviction;
            const cColor = c >= 90 ? "#30D158" : c >= 80 ? "#64D2FF" : "#FFD60A";
            const outColors = { strong: "#30D158", buy: "#FFD60A", hold: "#8E8E93" };
            const r = 18;
            const circ = 2 * Math.PI * r;
            const offset = circ * (1 - c / 100);
            return (
              <div key={h.ticker} className="glass fade-in pressable" style={{ ...styles.glass, padding: "20px", animationDelay: `${i * 65}ms`, cursor: "pointer" }}
                onClick={() => { setSelected(h.ticker); setTab("positions"); }}>
                <div style={{ display: "flex", gap: 14, alignItems: "flex-start" }}>
                  <div style={{ width: 48, height: 48, borderRadius: 13, flexShrink: 0, background: `linear-gradient(135deg, ${h.gradient[0]}, ${h.gradient[1]})`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 20, fontWeight: 800, color: "#fff", boxShadow: `0 4px 14px ${h.gradient[0]}40` }}>{h.icon}</div>
                  <div style={{ flex: 1 }}>
                    <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 8 }}>
                      <div>
                        <div style={{ fontSize: 17, fontWeight: 700, letterSpacing: "-0.03em" }}>{h.ticker}</div>
                        <div style={{ fontSize: 12, color: "rgba(255,255,255,0.28)", marginTop: 1 }}>{h.name}</div>
                      </div>
                      <div style={{ position: "relative", width: 44, height: 44, flexShrink: 0 }}>
                        <svg width="44" height="44" style={{ transform: "rotate(-90deg)" }}>
                          <circle cx="22" cy="22" r={r} fill="none" stroke="rgba(255,255,255,0.07)" strokeWidth="3" />
                          <circle cx="22" cy="22" r={r} fill="none" stroke={cColor} strokeWidth="3" strokeDasharray={circ} strokeDashoffset={offset} strokeLinecap="round" />
                        </svg>
                        <div style={{ position: "absolute", inset: 0, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 11, fontWeight: 700, color: cColor }}>{c}</div>
                      </div>
                    </div>
                    <div style={{ fontSize: 13, color: "rgba(255,255,255,0.48)", lineHeight: 1.6, marginBottom: 10 }}>{h.thesis.slice(0, 155)}...</div>
                    <div style={{ background: `${outColors[h.outlookType] || "#8E8E93"}12`, border: `1px solid ${outColors[h.outlookType] || "#8E8E93"}30`, borderRadius: 10, padding: "9px 14px", fontSize: 13, color: "rgba(255,255,255,0.62)", lineHeight: 1.5 }}>{h.outlook}</div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
        <div style={{ marginTop: 20, padding: "14px 18px", background: "rgba(255,255,255,0.03)", borderRadius: 14, border: "1px solid rgba(255,255,255,0.05)", fontSize: 11, color: "rgba(255,255,255,0.18)", textAlign: "center", lineHeight: 1.6 }}>
          Not financial advice · For personal tracking only · Always do your own research
        </div>
      </div>
    )}
  </div>
</div>
```

);
}
